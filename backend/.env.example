APP_NAME=VSA Foods Staff Management API
ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Primary MongoDB URI used by FastAPI app
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=iws

# Backward-compatible fallback if MONGODB_URI is not set
MONGO_URI=

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# Comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Preferred single frontend origin for production (Render static site URL)
FRONTEND_URL=

# Seed default users and sample staff records on startup
SEED_SAMPLE_DATA=True
